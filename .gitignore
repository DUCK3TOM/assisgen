# =============================================================================
# 文档与二进制资料 (Documentation & PDF — 不纳入版本库)
# 如需强制提交某个 PDF，在下方用 !path/to/file.pdf 取消忽略
# =============================================================================
# 注意：必须用 **/*.ext，单独 *.ext 只匹配仓库根目录，子目录文件不会被忽略
**/*.pdf
**/docs/**/*.pdf
**/documentation/**/*.pdf
**/document/**/*.pdf

# =============================================================================
# 图片（全仓库任意路径；常见后缀。需提交某文件时用 !相对路径 取消忽略）
# =============================================================================
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.bmp
**/*.tif
**/*.tiff
**/*.ico
**/*.svg
**/*.heic
**/*.avif

# =============================================================================
# 压缩包（全仓库任意路径；需提交时用 !相对路径 取消忽略）
# =============================================================================
**/*.zip
**/*.rar
**/*.7z
**/*.tar
**/*.gz
**/*.tgz
**/*.bz2
**/*.xz
**/*.lzma
**/*.cab
**/*.iso

# =============================================================================
# 1. 核心输出目录 (Core Output Directories)
# =============================================================================
**/data/output/
**/data/update_output/
**/data/pdf_outputs/
**/data/pdf_csv_exports/
**/data/prompt_turn_output/
**/data/pdf_prompt_turn_output/

# =============================================================================
# 2. 向量数据库与图数据库 (Vector & Graph Databases)
# =============================================================================
**/lancedb/
**/*.lance
**/*.db
**/*.sqlite
**/*.sqlite3
**/neo4j_data/
**/neo4j_admin/

# =============================================================================
# 3. 大数据格式与中间产物 (Big Data & Intermediate Formats)
# =============================================================================
**/*.parquet
**/*.csv

# =============================================================================
# 4. 大模型缓存与日志 (LLM Caches & Logs)
# =============================================================================
**/cache/
*semantic_cache*
**/*.log
graphrag.log

# =============================================================================
# 5. 上传的临时文件目录 (Uploaded Temp Files)
# =============================================================================
**/uploads/
**/temp/
**/tmp/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class

# =============================================================================
# 环境与密钥 (Environment & secrets — 不纳入版本库)
# =============================================================================
.env
.env.*
.venv/
venv/
env/
*.pem
*.key
secrets.json
secrets.yaml
secrets.yml

# =============================================================================
# 测试与工具缓存
# =============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# =============================================================================
# 前端 
# =============================================================================
node_modules/
**/node_modules/
dist/
**/dist/
.npm/
.pnpm-store/

# =============================================================================
# IDE 与系统文件
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# 其他日志目录（显式补充）
# =============================================================================
logs/
log/
**/logs/
